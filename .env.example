# ─── Database ───────────────────────────────────────────────────────────────
# Postgres + pgvector connection string
DATABASE_URL=postgresql://northstar:northstar@localhost:5432/northstar

# ─── Cache / Queues ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Embeddings ─────────────────────────────────────────────────────────────
# Provider: "openai" (default) or "local" (sentence-transformers, no API key)
EMBEDDING_PROVIDER=openai

# OpenAI — required when EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Embedding model name
# OpenAI:  text-embedding-3-small (1536 dims) | text-embedding-3-large (3072 dims)
# Local:   all-MiniLM-L6-v2 (384 dims) — set EMBEDDING_DIM accordingly
EMBEDDING_MODEL=text-embedding-3-small

# Must match the vector dimensions your model produces (default: 1536 for OpenAI)
EMBEDDING_DIM=1536

# ─── Retrieval ───────────────────────────────────────────────────────────────
# Hybrid ranking weights (must sum to 1.0)
RETRIEVAL_ALPHA=0.5    # semantic weight
RETRIEVAL_BETA=0.3     # keyword weight
RETRIEVAL_GAMMA=0.2    # recency weight

# Minimum confidence score for knowledge retrieval (0–1)
RETRIEVAL_CONFIDENCE_FLOOR=0.5

# Redis cache TTL in seconds
RETRIEVAL_CACHE_TTL=300

# ─── Agents (Scribe + Archivist) ────────────────────────────────────────────
# Anthropic API key — used for all LLM calls (Scribe and Archivist pipelines)
ANTHROPIC_API_KEY=sk-ant-...

# Claude model for Scribe  (default: claude-sonnet-4-6)
SCRIBE_MODEL=claude-sonnet-4-6

# Claude model for Archivist (default: claude-sonnet-4-6)
ARCHIVIST_MODEL=claude-sonnet-4-6

# Cosine distance threshold for contradiction detection (default: 0.15)
# Candidates closer than this to an existing validated knowledge item are flagged.
CONTRADICTION_THRESHOLD=0.15

# ─── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
